# Django
SKYLITE_DJANGO_SECRET_KEY=change-me
SKYLITE_DJANGO_DEBUG=false
SKYLITE_DJANGO_ALLOWED_HOSTS=weather.api.skylitefly.com,localhost,127.0.0.1

# Redis weather cache. Leave unset to use Django local-memory cache in simple local runs.
SKYLITE_REDIS_WEATHER_LOCATION=redis://redis:6379/0
SKYLITE_REDIS_WEATHER_PASSWORD=
SKYLITE_REDIS_WEATHER_KEY_PREFIX=weather

# AVWX fallback. NOAA batch cache works without this, but cache misses need a token.
SKYLITE_AVWX_TOKEN=
SKYLITE_AVWX_BASE_URL=https://avwx.rest/api
